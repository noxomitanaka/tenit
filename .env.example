# ─── 必須 (Required) ─────────────────────────────────────────────────────────
# NextAuth シークレット (openssl rand -base64 32 で生成)
NEXTAUTH_SECRET=your-secret-here

# アプリのURL
NEXTAUTH_URL=http://localhost:3000

# ─── データベース (Database) ──────────────────────────────────────────────────
# 省略時: ./local.db にSQLiteファイルを自動作成 (ゼロ設定)
# Turso:  libsql://your-db.turso.io?authToken=your-token
# PostgreSQL (Neon/Supabase/Railway): postgresql://user:pass@host:5432/tenit
# DATABASE_URL=file:./local.db

# ─── メール通知 (Email - Optional) ───────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="テニット <noreply@yourdomain.com>"

# ─── LINE通知 (LINE Messaging API - Optional) ────────────────────────────────
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=
